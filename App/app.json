{
  "expo": {
    "name": "SummitSteps",
    "slug": "SummitSteps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "summitsteps",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "infoPlist": {
        "NSHealthShareUsageDescription": "Allow $(PRODUCT_NAME) to read your health data.",
        "NSHealthUpdateUsageDescription": "Allow $(PRODUCT_NAME) to update your health data."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "plugins": ["@kingstinct/react-native-healthkit"],
    "android": {
      "package": "com.anonymous.App"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-background-task",
      "expo-sqlite",
      "react-native-health",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26
          }
        }
      ],
      "expo-health-connect",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
