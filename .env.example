# ================================
# Database URLs (per service)
# ================================
USERS_DATABASE_URL=postgresql://user:password@host:5432/users_db
MOUNTAINS_DATABASE_URL=postgresql://user:password@host:5432/mountains_db
PROGRESS_DATABASE_URL=postgresql://user:password@host:5432/progress_db
GROUPS_DATABASE_URL=postgresql://user:password@host:5432/groups_db
EVENTS_DATABASE_URL=postgresql://user:password@host:5432/events_db

# ================================
# AWS (S3 + SES)
# ================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-2
AWS_S3_BUCKET_NAME=your_s3_bucket_name
SES_REGION=us-east-1

# ================================
# Auth
# ================================
AUTH_SECRET_KEY=your_secret_key_min_32_chars
ALGORITHM=HS256

# ================================
# Redis (auth-service)
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ================================
# Admin Seed
# ================================
INITIAL_ADMIN_EMAIL=your_admin@email.com

# ================================
# Email (Resend — auth + verification emails)
# ================================
RESEND_API_KEY=re_2fGB7zQT_Bc4NZQUHtoC8JKKzUguZg1a9
FROM_EMAIL=noreply@summitstepsapp.com
